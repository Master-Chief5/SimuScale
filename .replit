run = "streamlit run main.py --server.port 8080 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableXsrfProtection false"

entrypoint = "main.py"
modules = ["python-3.11"]

hidden = [".pythonlibs", ".config", "venv", "__pycache__"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "streamlit run main.py --server.port 8080 --server.address 0.0.0.0 --server.headless true"]

[[ports]]
localPort = 8080
externalPort = 80
